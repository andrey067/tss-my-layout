# Dual Screens — Environment Variables
# Copy this file to .env and adjust values.

# Override serial port auto-detection (optional)
# SERIAL_PORT=/dev/ttyACM0
DISPLAY_MODE=reverse_landscape  # options: landscape, reverse_landscape, portrait, reverse_portrait
CALIBRATION_MODE=false
ORIENTATION_MODE=false

# Render cadence
REFRESH_INTERVAL=1

# Screen rotation windows (seconds)
RESOURCES_SCREEN_SECONDS=30
KUMA_SCREEN_SECONDS=30

# Uptime Kuma
KUMA_ENABLED=true
KUMA_URL=http://127.0.0.1:3002
KUMA_TOKEN=
KUMA_TIMEOUT=8
KUMA_POLL_INTERVAL=10
KUMA_VERIFY_SSL=true
KUMA_MAX_ROWS=18

# Enrich monitor rows with docker port mappings
SHOW_DOCKER_PORTS=true
